@using PokemonBattleSimulator.Models.Enum;
@model TeamViewModel

<template id="pokemon-options-template">
    <option value="Select a Pokemon">Select a Pokemon</option>
    @foreach (var pokemon in Enum.GetValues(typeof(Pokemon)).Cast<Pokemon>())
    {
        <option value="@((int)pokemon)">@pokemon</option>
    }
</template>

<div id="team_@Model.TeamId.ToString()_pokemon-container">
    <div class="col-sm-12 pokemon">
        <div class="input-group">
            @Html.DropDownList(
            "pokemon",
            new SelectList(
            Enum.GetValues(typeof(Pokemon)).Cast<Pokemon>().Select(p => new { Value = (int)p, Text = p.ToString() }),
            "Value", "Text"
            ),
            "Select a Pokémon",
            new { @class = "form-control pokemon-dropdown", id = $"team_{@Model.TeamId.ToString()}_pokemon_1" }
            )
        </div>
        <div id="selected-pokemon-1">
        </div>
    </div>
</div>
<button id="team_@Model.TeamId.ToString()_add-pokemon-btn">+</button>